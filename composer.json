{
    "name": "waaseyaa/relationship",
    "description": "Reusable relationship primitives for Waaseyaa applications",
    "type": "library",
    "license": "GPL-2.0-or-later",
    "autoload": {
        "psr-4": {
            "Waaseyaa\\Relationship\\": "src/"
        }
    },
    "require": {
        "php": ">=8.3",
        "waaseyaa/access": "^1.1",
        "waaseyaa/database-legacy": "^1.1",
        "waaseyaa/entity": "^1.1",
        "waaseyaa/workflows": "^1.1"
    },
    "extra": {
        "waaseyaa": {
            "providers": ["Waaseyaa\\Relationship\\RelationshipServiceProvider"]
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
